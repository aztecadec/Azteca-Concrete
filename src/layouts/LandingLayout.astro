---
import { ClientRouter } from 'astro:transitions';
import SchemaWebSite from '../components/SchemaWebSite.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  phoneNumber?: string;
}

const { 
  title, 
  description = "Get a free estimate today.", 
  phoneNumber = "(224) 245-4044" 
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/images/Site-Icon.png" />
		<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
	<title>{title}</title>

	<!-- Schema markup -->
	<SchemaWebSite />

	<!-- Google Tag Manager -->
	<script is:inline>
		(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-MQVHV9DS');
	</script>
	<!-- End Google Tag Manager -->

    <ClientRouter />
	</head>
	<body class="min-h-screen bg-[var(--surface-base)] text-[var(--text-on-dark)] Selection:bg-amber-500 selection:text-black">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MQVHV9DS"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		
    <!-- Simplified Squeeze Page Header -->
    <header class="w-full bg-[var(--color-fir-700)] py-4 sticky top-0 z-50 border-b border-[rgba(255,255,255,0.05)] shadow-md">
      <div class="container-main mx-auto flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2">
          <img src="/images/Azteca-Concrete-Logo White.webp" alt="Azteca Concrete Decoration" class="h-14 w-auto drop-shadow-md" />
        </a>

        <!-- Phone CTA -->
        <a href={`tel:${phoneNumber.replace(/[^0-9]/g, '')}`} class="btn-primary text-sm whitespace-nowrap !px-6 !py-2 hidden sm:inline-flex">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          {phoneNumber}
        </a>
      </div>
    </header>

    <main>
		  <slot />
    </main>

    <!-- Simplified Squeeze Page Footer -->
    <footer class="bg-[var(--color-fir-900)] py-8 border-t border-[rgba(255,255,255,0.05)] mt-12 text-center text-sm text-[var(--color-fir-300)]">
      <div class="container-main mx-auto">
        <p>&copy; {new Date().getFullYear()} Azteca Concrete Decoration. All rights reserved.</p>
        <div class="mt-2 text-xs flex justify-center space-x-4">
          <a href="/privacy-policy" class="hover:text-[var(--color-accent)] transition-colors">Privacy Policy</a>
          <a href="/terms-of-service" class="hover:text-[var(--color-accent)] transition-colors">Terms of Service</a>
        </div>
      </div>
    </footer>

    <!-- Mobile click-to-call FAB -->
    <a href={`tel:${phoneNumber.replace(/[^0-9]/g, '')}`} class="mobile-call-fab" id="mobileCallFab" aria-label="Call us now">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
      </svg>
      <span>Call Now</span>
    </a>

    <script is:inline>
      (function () {
        var fab = document.getElementById('mobileCallFab');
        var lastY = window.scrollY;
        var threshold = 120;

        function onScroll() {
          var y = window.scrollY;
          if (y > threshold && y < lastY) {
            fab.classList.add('mobile-call-fab--visible');
          } else {
            fab.classList.remove('mobile-call-fab--visible');
          }
          lastY = y;
        }

        window.removeEventListener('scroll', window._fabScroll);
        window._fabScroll = onScroll;
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>
	</body>
</html>

<style is:global>
  @reference "../styles/global.css";

  .mobile-call-fab {
    display: none;
    align-items: center;
    gap: 0.5rem;
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 3rem));
    z-index: 100;
    background: var(--color-accent);
    color: var(--color-fir-900);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.875rem 2rem;
    border-radius: 9999px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.2s ease;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .mobile-call-fab {
      display: flex;
    }
  }

  .mobile-call-fab--visible {
    transform: translateX(-50%) translateY(0) !important;
  }

  .mobile-call-fab:active {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }
</style>
