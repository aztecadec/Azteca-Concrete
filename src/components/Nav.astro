---
const links = [
  { num: "01", label: "Concrete Services", href: "/concrete-services-carpentersville" },
  { num: "02", label: "Gallery",           href: "/gallery" },
  { num: "03", label: "About",             href: "/about" },
{ num: "04", label: "Contact", href: "/contact" },
];
---

<nav class="nav">
  <div class="nav__bar container-main">

    <!-- Logo -->
    <a href="/" class="nav__logo">
      <img src="/images/Azteca-Concrete-Logo White.webp" alt="Azteca Concrete Decoration" class="nav__logo-img" />
    </a>

    <!-- Desktop links -->
    <div class="nav__links">
      {links.map((l) => (
        <a href={l.href} class="nav__link">{l.label}</a>
      ))}
      <a href="/book-a-call#form" class="nav__cta btn btn-primary btn-sm">
        Transform My Floor
      </a>
    </div>

    <!-- Hamburger -->
    <button class="nav__burger" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line nav__burger-line--short"></span>
    </button>

  </div>
</nav>

<!-- Backdrop -->
<div class="nav__backdrop" id="nav-backdrop"></div>

<!-- Full-screen mobile drawer -->
<div class="nav__drawer" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation menu">

  <!-- Drawer header -->
  <div class="nav__drawer-header">
    <a href="/" class="nav__drawer-logo">
      <img src="/images/Azteca-Concrete-Logo White.webp" alt="Azteca Concrete Decoration" class="nav__logo-img" />
    </a>
    <button class="nav__close" id="nav-close" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Drawer links -->
  <nav class="nav__drawer-nav">
    {links.map((l) => (
      <a href={l.href} class="nav__drawer-link">
        <span class="nav__drawer-num">{l.num}</span>
        <span class="nav__drawer-label">{l.label}</span>
        <svg class="nav__drawer-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    ))}
  </nav>

  <!-- Drawer footer -->
  <div class="nav__drawer-footer">
    <a href="/book-a-call#form" class="btn btn-primary nav__drawer-cta">
      Transform My Floor
    </a>
    <div class="nav__drawer-contact">
      <a href="tel:+12242454044" class="nav__drawer-phone">(224) 245-4044</a>
      <span class="nav__drawer-hours">Mon–Sat · 8:00 AM – 5:00 PM</span>
    </div>
  </div>

</div>

<script>
  function initNav() {
    const toggle   = document.getElementById('nav-toggle');
    const closeBtn = document.getElementById('nav-close');
    const backdrop = document.getElementById('nav-backdrop');
    const drawer   = document.getElementById('mobile-menu');

    function openMenu() {
      drawer?.classList.add('nav__drawer--open');
      backdrop?.classList.add('nav__backdrop--visible');
      toggle?.classList.add('nav__burger--open');
      toggle?.setAttribute('aria-expanded', 'true');
      drawer?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      drawer?.classList.remove('nav__drawer--open');
      backdrop?.classList.remove('nav__backdrop--visible');
      toggle?.classList.remove('nav__burger--open');
      toggle?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    toggle?.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop?.addEventListener('click', closeMenu);

    drawer?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }

  // Run on first load and after every View Transition navigation
  initNav();
  document.addEventListener('astro:page-load', initNav);
</script>

<style>
  /* ─── Nav Bar ────────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 200;
    background-color: var(--color-fir-700);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav__bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
  }

  .nav__logo {
    display: flex;
    text-decoration: none;
  }

  .nav__logo-img {
    height: 36px;
    width: auto;
    display: block;
  }

  /* ─── Desktop Links ──────────────────────────────────── */
  .nav__links {
    display: none;
    align-items: center;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .nav__links {
      display: flex;
    }
  }

  .nav__link {
    font-size: var(--text-sm);
    color: var(--text-on-dark-muted);
    text-decoration: none;
    transition: color var(--transition-base);
    font-weight: 400;
  }

  .nav__link:hover {
    color: var(--color-white);
  }

  .nav__cta {
    font-size: var(--text-xs) !important;
    white-space: nowrap;
  }

  /* ─── Hamburger ──────────────────────────────────────── */
  .nav__burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .nav__burger {
      display: none;
    }
  }

  .nav__burger-line {
    display: block;
    width: 24px;
    height: 1.5px;
    background-color: var(--color-white);
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                opacity   0.25s ease,
                width     0.25s ease;
  }

  .nav__burger-line--short {
    width: 16px;
  }

  .nav__burger--open .nav__burger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav__burger--open .nav__burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav__burger--open .nav__burger-line:nth-child(3) {
    width: 24px;
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ─── Backdrop ───────────────────────────────────────── */
  .nav__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    z-index: 210;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .nav__backdrop--visible {
    opacity: 1;
    pointer-events: all;
  }

  /* ─── Drawer ─────────────────────────────────────────── */
  .nav__drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100vw;
    max-width: 480px;
    background-color: var(--color-fir-900);
    z-index: 220;
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav__drawer--open {
    transform: translateX(0);
  }

  /* ─── Drawer Header ──────────────────────────────────── */
  .nav__drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-6) var(--space-8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }

  .nav__drawer-logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .nav__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-on-dark-muted);
    cursor: pointer;
    transition: background var(--transition-base), color var(--transition-base);
  }

  .nav__close:hover {
    background: rgba(233, 193, 118, 0.1);
    color: var(--color-accent);
    border-color: rgba(233, 193, 118, 0.2);
  }

  /* ─── Drawer Nav Links ───────────────────────────────── */
  .nav__drawer-nav {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-4) 0;
  }

  .nav__drawer-link {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-8);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    opacity: 0;
    transform: translateX(24px);
    transition: opacity 0.35s ease, transform 0.35s ease, background 0.2s ease;
  }

  .nav__drawer-link:nth-child(1) { transition-delay: 0.07s; }
  .nav__drawer-link:nth-child(2) { transition-delay: 0.12s; }
  .nav__drawer-link:nth-child(3) { transition-delay: 0.17s; }
  .nav__drawer-link:nth-child(4) { transition-delay: 0.22s; }

  .nav__drawer--open .nav__drawer-link {
    opacity: 1;
    transform: translateX(0);
  }

  .nav__drawer-link:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .nav__drawer-link:hover .nav__drawer-num {
    color: var(--color-accent);
  }

  .nav__drawer-link:hover .nav__drawer-label {
    color: var(--color-white);
  }

  .nav__drawer-link:hover .nav__drawer-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .nav__drawer-num {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-on-dark-subtle);
    letter-spacing: var(--tracking-wide);
    min-width: 24px;
    transition: color var(--transition-base);
  }

  .nav__drawer-label {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 1.875rem);
    font-weight: 500;
    color: var(--text-on-dark-muted);
    flex: 1;
    transition: color var(--transition-base);
  }

  .nav__drawer-arrow {
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  /* ─── Drawer Footer ──────────────────────────────────── */
  .nav__drawer-footer {
    padding: var(--space-8);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    flex-shrink: 0;
  }

  .nav__drawer-cta {
    width: 100%;
    justify-content: center;
    text-align: center;
    font-size: var(--text-base) !important;
  }

  .nav__drawer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .nav__drawer-phone {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
    transition: opacity var(--transition-base);
  }

  .nav__drawer-phone:hover {
    opacity: 0.8;
  }

  .nav__drawer-hours {
    font-size: var(--text-xs);
    color: var(--text-on-dark-subtle);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
</style>
