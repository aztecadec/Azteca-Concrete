---
const areas = [
  "Carpentersville", "Elgin", "Algonquin", "Barrington",
  "Crystal Lake", "Huntley", "East Dundee", "West Dundee",
  "Gilberts", "Hampshire", "Pingree Grove", "Sleepy Hollow",
];
---

<section id="areas" class="service-areas">
  <div class="service-areas__container container-main section-padding">
    <div class="service-areas__inner">
      <div class="service-areas__content">
        <p class="service-areas__eyebrow label-category">Where We Work</p>
        <h2 class="section-title service-areas__title">Proudly Serving Carpentersville & Surrounding Areas</h2>
        <p class="service-areas__description">
          We're a local crew — not a franchise. When you call us, you get the same team that's been doing this work for over a decade across Carpentersville and the surrounding communities. No subs, no shortcuts.
        </p>
        <a href="/book-a-call" class="btn btn-primary service-areas__cta">
          Transform My Floor
        </a>
      </div>

      <div class="service-areas__areas">
        <p class="service-areas__areas-label">Cities & Towns We Cover</p>
        <ul class="service-areas__list">
          {areas.map((area) => (
            <li class="service-areas__list-item">
              <svg class="service-areas__pin" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              {area}
            </li>
          ))}
        </ul>
        <p class="service-areas__note">Not on the list? Call us — we may still cover your area.</p>
        <div class="service-areas__map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d189551.3855991456!2d-88.229234!3d42.070183500000006!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x880f0ff5d75d7cd1%3A0x96bb000f67422a1a!2sAzteca%20Concrete%20Decoration!5e0!3m2!1sen!2sus!4v1774392353502!5m2!1sen!2sus"
            class="service-areas__map-iframe"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Azteca Concrete Decoration location"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .service-areas {
    background-color: var(--color-cream);
  }

  .service-areas__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (min-width: 1024px) {
    .service-areas__inner {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  .service-areas__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .service-areas__eyebrow {
    color: var(--color-fir-500);
  }

  .service-areas__title {
    color: var(--color-fir-700);
  }

  .service-areas__description {
    font-size: var(--text-lg);
    color: var(--color-fir-600);
    line-height: var(--leading-relaxed);
    font-weight: 300;
    max-width: 34rem;
  }

  .service-areas__cta {
    align-self: flex-start;
  }

  .service-areas__areas {
    background-color: var(--color-fir-700);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .service-areas__areas-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-on-dark-subtle);
    margin-bottom: var(--space-5);
  }

  .service-areas__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  @media (min-width: 480px) {
    .service-areas__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-areas__list-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-on-dark-muted);
    font-weight: 400;
  }

  .service-areas__pin {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .service-areas__note {
    font-size: var(--text-xs);
    color: var(--text-on-dark-subtle);
    font-style: italic;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .service-areas__map {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .service-areas__map-iframe {
    width: 100%;
    height: 260px;
    display: block;
    border: 0;
  }
</style>
