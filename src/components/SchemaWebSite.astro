---
// WebSite Schema - Include on ALL pages
// Provides search functionality sitewide

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://aztecaconcrete.com/#website",
  "name": "Azteca Concrete Decoration",
  "url": "https://aztecaconcrete.com",
  "description": "Professional concrete finishing, epoxy flooring, and decorative concrete services in Carpentersville, IL and the Fox Valley area.",
  "publisher": {
    "@type": "GeneralContractor",
    "@id": "https://aztecaconcrete.com/#business",
    "name": "Azteca Concrete Decoration"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://aztecaconcrete.com/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(websiteSchema, null, 2)} />
