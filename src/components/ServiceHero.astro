---
interface Props {
  title: string;
  subtitle: string;
  image: string;
}

const { title, subtitle, image } = Astro.props;
---

<section class="service-hero">
  <div class="service-hero__overlay"></div>
  <div class="service-hero__container container-main">
    <div class="service-hero__content">
      <h1 class="service-hero__title">{title}</h1>
      <p class="service-hero__subtitle">{subtitle}</p>
      <div class="service-hero__actions">
        <a href="/book-a-call#form" class="btn btn-primary">
          Transform My Floor
        </a>
        <a href="tel:+12242454044" class="btn btn-secondary">
          Call Now
        </a>
      </div>
    </div>
  </div>
  <div class="service-hero__image-wrapper">
    <img src={image} alt={title} class="service-hero__image" />
  </div>
</section>

<style>
  .service-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    background-color: var(--surface-container-low);
    overflow: hidden;
    padding-top: 8rem;
    padding-bottom: var(--space-16);
  }

  .service-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(5, 12, 8, 0.95) 0%,
      rgba(5, 12, 8, 0.8) 50%,
      rgba(5, 12, 8, 0.4) 100%
    );
    z-index: 10;
  }

  .service-hero__container {
    position: relative;
    z-index: 20;
    width: 100%;
  }

  .service-hero__content {
    max-width: 700px;
  }

  .service-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    color: var(--color-accent);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }

  .service-hero__subtitle {
    font-size: var(--text-xl);
    color: var(--text-on-dark-muted);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .service-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .service-hero__image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .service-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
  }
</style>
