---
---

<section class="hero">
  <!-- Subtle ambient glow background -->
  <div class="hero__glow"></div>

  <div class="hero__container container-main">
    <!-- Left Column: Content -->
    <div class="hero__content">
      <div class="hero__text">
        <h1 class="hero-title">
          Same Floor.<br/>Completely Different Room.
        </h1>
        <p class="hero__description">
          We don't install floors. We transform the ones you already have. Epoxy coatings, crack repair, decorative finishes — done right, built to last, impossible to ignore.
        </p>
      </div>

      <div class="hero__actions">
        <a href="/book-a-call#form" class="btn btn-primary">
          Transform My Floor
        </a>
        <a href="#gallery" class="btn btn-secondary group">
          See the Results
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <!-- Social Proof -->
      <div class="hero__social-proof">
        <div class="hero__avatars">
          <img src="/images/Avatars/Mary Johnson.webp" alt="" class="hero__avatar" />
          <img src="/images/Avatars/Mark B.webp" alt="" class="hero__avatar" />
          <img src="/images/Avatars/Dave Weinstein.webp" alt="" class="hero__avatar" />
        </div>
        <p class="hero__testimonial">
          "I was embarrassed by my garage floor for years. Now it's the first thing I show people." <br/>
          <span class="hero__testimonial-author">— 500+ Surfaces Restored. Every One Still Standing.</span>
        </p>
      </div>
    </div>

    <!-- Right Column: Image + Badge -->
    <div class="hero__visual">
      <div class="hero__image-wrapper">
        <div class="hero__image-inner">
          <img
            src="/images/Decorative-Concrete-Outside-Patio.webp"
            alt="Artisanal concrete sunroom"
            class="hero__image"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <!-- Badge -->
          <div class="hero__badge">
            <div class="hero__badge-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div class="hero__badge-content">
              <p class="hero__badge-title">Lifetime Resilience</p>
              <p class="hero__badge-text">Stain-proof. Crack-proof. Time-proof. Built to outlast everything above it.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Decorative background accent -->
      <div class="hero__accent"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    padding-top: 8rem;
    padding-bottom: var(--space-16);
    background-color: var(--surface-container-low);
    overflow: hidden;
  }

  .hero__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background-color: var(--color-fir-500);
    opacity: 0.3;
    filter: blur(var(--blur-2xl));
    border-radius: var(--radius-full);
    pointer-events: none;
  }

  .hero__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-16);
    align-items: center;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 1024px) {
    .hero__container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hero__description {
    font-size: var(--text-lg);
    color: var(--text-on-dark-muted);
    max-width: 36rem;
    line-height: var(--leading-relaxed);
  }

  @media (min-width: 768px) {
    .hero__description {
      font-size: var(--text-xl);
    }
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    padding-top: var(--space-2);
  }

  .hero__social-proof {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 640px) {
    .hero__social-proof {
      align-items: center;
    }
  }

  .hero__avatars {
    flex-shrink: 0;
  }

  .hero__avatars {
    display: flex;
  }

  .hero__avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    border: 2px solid var(--surface-container-low);
    object-fit: cover;
    margin-left: -0.75rem;
  }

  .hero__avatar:first-child {
    margin-left: 0;
  }

  .hero__testimonial {
    font-size: var(--text-sm);
    color: var(--text-on-dark-subtle);
    font-style: italic;
  }

  .hero__testimonial-author {
    color: var(--text-on-dark-muted);
    font-weight: 600;
    font-style: normal;
  }

  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero__image-wrapper {
    width: 100%;
    max-width: 486px;
    aspect-ratio: 4 / 4.5;
    border-radius: var(--radius-3xl);
    overflow: hidden;
    box-shadow: var(--shadow-concrete);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--space-3);
    background-color: rgba(255, 255, 255, 0.05);
  }

  @media (min-width: 768px) {
    .hero__image-wrapper {
      aspect-ratio: 4 / 5;
    }
  }

  @media (min-width: 1024px) {
    .hero__image-wrapper {
      aspect-ratio: 4 / 4.5;
    }
  }

  .hero__image-inner {
    width: 100%;
    height: 100%;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    position: relative;
    background-color: var(--color-fir-800);
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__badge {
    position: absolute;
    bottom: var(--space-10);
    left: var(--space-8);
    right: var(--space-8);
    background-color: rgba(10, 24, 15, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    transition: background-color var(--transition-base);
  }

  .hero__badge:hover {
    background-color: rgba(26, 59, 38, 0.9);
  }

  .hero__badge-icon {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-lg);
    background-color: rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-accent-light);
    flex-shrink: 0;
  }

  .hero__badge-title {
    color: var(--color-accent-light);
    font-weight: 700;
    font-size: var(--text-base);
  }

  .hero__badge-text {
    color: var(--text-on-dark-subtle);
    font-size: 11px;
  }

  .hero__accent {
    position: absolute;
    z-index: -10;
    bottom: -2rem;
    right: -2rem;
    width: 16rem;
    height: 16rem;
    background-color: var(--color-primary-dark);
    opacity: 0.1;
    filter: blur(var(--blur-xl));
    border-radius: var(--radius-full);
  }
</style>
