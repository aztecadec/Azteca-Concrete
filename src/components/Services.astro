---
const services = [
  {
    title: "Epoxy Floor Coatings",
    description: "Transform any concrete surface into a seamless, high-gloss finish. Garage floors, basements, retail spaces — built to handle heavy use and look incredible doing it.",
    image: "Newly-Epoxy-Garage-Floor.webp",
    tag: "Most Popular",
    href: "/epoxy-flooring-carpentersville",
  },
  {
    title: "Concrete Crack Repair",
    description: "Cracks don't fix themselves — they spread. We seal, fill, and restore damaged concrete before small problems become expensive ones.",
    image: "Crack-Concrete-After.webp",
    tag: null,
    href: "/concrete-repair-carpentersville",
  },
  {
    title: "Concrete Resurfacing",
    description: "Worn, stained, or pitted concrete gets a second life. We resurface and refinish existing slabs so they look better than the day they were poured.",
    image: "Concrete-Resurfacing-After.webp",
    tag: null,
    href: "/concrete-resurfacing-carpentersville",
  },
  {
    title: "Pool Deck Coating",
    description: "Slip-resistant, heat-resistant, and stunning. We coat pool decks to survive the elements and make your outdoor space the envy of the neighborhood.",
    image: "Pool-Deck-After.webp",
    tag: null,
    href: "/pool-decking-carpentersville",
  },
  {
    title: "Stamped Concrete",
    description: "The look of stone, brick, or wood — without the price tag. Stamped concrete adds serious curb appeal to patios, walkways, and driveways.",
    image: "Stamp-Patio-Concrete.webp",
    tag: null,
    href: "/stamped-concrete-carpentersville",
  },
  {
    title: "Driveway & Porch Refinishing",
    description: "Your driveway and porch take a beating every day. We restore, coat, and seal them so they can take another decade of abuse and still look sharp.",
    image: "Newly-Coated-Driveway.webp",
    tag: null,
    href: "/concrete-refinishing-carpentersville",
  },
];
---

<section id="services" class="services">
  <div class="services__container container-main section-padding">
    <div class="services__header">
      <p class="services__eyebrow label-category">What We Do</p>
      <h2 class="section-title services__title">Every Surface. Done Right.</h2>
      <p class="services__subtitle">
        From cracked driveways to garage floors, we handle it all — with the same obsessive attention to detail on every single job.
      </p>
    </div>

    <div class="services__grid">
      {services.map((service) => (
        <a href={service.href} class="services__card">
          <div class="services__image-wrapper">
            <img
              src={`/images/${service.image}`}
              alt={service.title}
              class="services__image"
            />
            {service.tag && (
              <span class="services__tag">{service.tag}</span>
            )}
          </div>
          <div class="services__card-body">
            <h3 class="services__card-title">{service.title}</h3>
            <p class="services__card-description">{service.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-cream);
  }

  .services__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-16);
    max-width: 42rem;
  }

  .services__eyebrow {
    color: var(--color-fir-500);
    letter-spacing: var(--tracking-wide);
  }

  .services__title {
    color: var(--color-fir-700);
  }

  .services__subtitle {
    font-size: var(--text-lg);
    color: var(--color-fir-600);
    line-height: var(--leading-relaxed);
    font-weight: 300;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .services__card {
    background-color: var(--color-fir-800);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform var(--transition-base), border-color var(--transition-base);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .services__card:hover {
    transform: translateY(-4px);
    border-color: rgba(233, 193, 118, 0.2);
  }

  .services__image-wrapper {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .services__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .services__card:hover .services__image {
    transform: scale(1.05);
  }

  .services__tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dark));
    color: var(--color-fir-800);
    font-size: var(--text-xs);
    font-weight: 700;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .services__card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .services__card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-accent-light);
  }

  .services__card-description {
    font-size: var(--text-sm);
    color: var(--text-on-dark-muted);
    line-height: var(--leading-relaxed);
    font-weight: 300;
  }
</style>
